doctype html
block vars
  - var bodyclass = null;
html(lang='en')
  head
    block head
      meta(charset='utf-8')
      meta(http-equiv='X-UA-Compatible', content='IE=edge,chrome=1')
      meta(name='viewport', content='width=device-width, initial-scale=1')
      title
        block title
          = locals.name
      link(rel='alternate', href=locals.url+'/feed.xml', type='application/rss+xml', title=locals.description)
      link(rel='stylesheet', href='//fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&family=JetBrains+Mono:wght@400;500;600&display=swap')
      link(rel='stylesheet', href=contents.css['main.css'].url)
      link#hljs-theme(rel='stylesheet', href='//cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.0/styles/atom-one-light.min.css')
      script.
        (function() {
          const getTheme = () => localStorage.getItem('theme') || 'dark';
          const setTheme = (theme) => {
            localStorage.setItem('theme', theme);
            document.documentElement.setAttribute('data-theme', theme);
          };
          setTheme(getTheme());
        })();
  body(class=bodyclass)
    // Desktop theme toggle — hidden on mobile
    button.theme-toggle(onclick="toggleTheme()" aria-label="Toggle dark mode")

    // Mobile hamburger — hidden on desktop
    button.hamburger(id="hamburger" onclick="openDrawer()" aria-label="Open menu")
      span
      span
      span

    // Mobile drawer
    div.drawer-overlay(id="drawer-overlay" onclick="closeDrawer()")
    aside.drawer(id="drawer")
      div.drawer-header
        a.drawer-home(href="/") ← Home
        button.drawer-theme(onclick="toggleTheme()" aria-label="Toggle theme")
        button.drawer-close(onclick="closeDrawer()" aria-label="Close") ✕
      div.drawer-body(id="drawer-body")

    header.header
      div.content-wrap
        block header
          div.logo
            h1
              a(href=locals.url)= locals.name
            p.description= locals.description
    div#content
      div.content-wrap
        block content
          h2 Welcome to zombocom!
    footer
      div.content-wrap
        block footer
          section.about
            !=contents['about.md'].html
          section.copy
            p &copy; #{ new Date().getFullYear() } #{ locals.owner } &mdash; powered by&nbsp;
              a(href='https://github.com/jnordberg/wintersmith') Wintersmith
              //- please leave the "powered by" if you use the design

    script(src='//cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.0/highlight.min.js')
    script.
      // Drawer
      function openDrawer() {
        document.getElementById('drawer').classList.add('drawer-open');
        document.getElementById('drawer-overlay').classList.add('drawer-overlay-visible');
        document.getElementById('hamburger').setAttribute('aria-expanded', 'true');
      }

      function closeDrawer() {
        document.getElementById('drawer').classList.remove('drawer-open');
        document.getElementById('drawer-overlay').classList.remove('drawer-overlay-visible');
        document.getElementById('hamburger').setAttribute('aria-expanded', 'false');
      }

      // Table of contents — article pages only
      document.addEventListener('DOMContentLoaded', function() {
        if (!document.body.classList.contains('article-detail')) return;

        var content = document.querySelector('section.content');
        if (!content) return;

        var headings = content.querySelectorAll('h2, h3');
        if (headings.length < 2) return;

        function slugify(text) {
          return text.trim()
            .toLowerCase()
            .replace(/[^\w\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-{2,}/g, '-');
        }

        var usedIds = {};
        headings.forEach(function(h) {
          if (!h.id) {
            var base = slugify(h.textContent);
            var id = base;
            var n = 2;
            while (usedIds[id]) { id = base + '-' + n++; }
            h.id = id;
          }
          usedIds[h.id] = true;
        });

        var nav = document.createElement('nav');
        nav.className = 'toc';
        nav.setAttribute('aria-label', 'Table of contents');

        var titleEl = document.createElement('div');
        titleEl.className = 'toc-title';
        titleEl.innerHTML = '<span>On this page</span>';
        nav.appendChild(titleEl);

        var list = document.createElement('ul');
        list.className = 'toc-list';

        headings.forEach(function(h) {
          var li = document.createElement('li');
          li.className = 'toc-item toc-' + h.tagName.toLowerCase();
          var a = document.createElement('a');
          a.href = '#' + h.id;
          a.className = 'toc-link';
          a.textContent = h.textContent;
          a.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById(h.id).scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, null, '#' + h.id);
            closeDrawer();
          });
          li.appendChild(a);
          list.appendChild(li);
        });

        nav.appendChild(list);

        var hamburger = document.getElementById('hamburger');
        var isMobile = hamburger && window.getComputedStyle(hamburger).display !== 'none';

        if (isMobile) {
          // Mobile: put TOC inside the drawer
          var drawerBody = document.getElementById('drawer-body');
          if (drawerBody) drawerBody.appendChild(nav);
        } else {
          // Desktop: insert as sticky sidebar
          var article = document.querySelector('article.article');
          if (!article) return;
          article.parentElement.classList.add('article-with-toc');
          article.parentElement.insertBefore(nav, article);
        }

        // Highlight active heading via IntersectionObserver
        var tocLinks = [].slice.call(nav.querySelectorAll('.toc-link'));
        var activeLink = null;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var href = '#' + entry.target.id;
              if (activeLink) activeLink.classList.remove('toc-active');
              activeLink = tocLinks.find(function(l) { return l.getAttribute('href') === href; }) || null;
              if (activeLink) activeLink.classList.add('toc-active');
            }
          });
        }, { rootMargin: '-15% 0px -75% 0px', threshold: 0 });

        headings.forEach(function(h) { observer.observe(h); });
      });

    script.
      function getTheme() {
        return document.documentElement.getAttribute('data-theme') || 'light';
      }

      function updateHljsTheme() {
        const theme = getTheme();
        const hljsLink = document.getElementById('hljs-theme');
        const themeName = theme === 'dark' ? 'atom-one-dark' : 'atom-one-light';
        hljsLink.href = `//cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.0/styles/${themeName}.min.css`;
        if (typeof hljs !== 'undefined') {
          document.querySelectorAll('pre code').forEach(block => {
            delete block.dataset.highlighted;
            hljs.highlightElement(block);
          });
        }
      }

      function toggleTheme() {
        const currentTheme = getTheme();
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', newTheme);
        document.documentElement.setAttribute('data-theme', newTheme);
        updateHljsTheme();
      }

      document.addEventListener('DOMContentLoaded', function() {
        updateHljsTheme();
      });
