{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "default": "Dan Marshall",
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ai",
          "ai assisted development",
          "career",
          "developer tools",
          "dotnet",
          "finance",
          "llm",
          "local ai",
          "productivity",
          "static sites",
          "tdd",
          "testing"
        ]
      }
    },
    "heroImage": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 70
    },
    "template": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "description"
  ]
}