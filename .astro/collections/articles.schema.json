{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "author": {
      "default": "Dan Marshall",
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "heroImage": {
      "type": "string"
    },
    "heroImageCrop": {
      "default": false,
      "type": "boolean"
    },
    "heroImagePosition": {
      "default": "center",
      "type": "string"
    },
    "heroImageScale": {
      "default": 1,
      "type": "number"
    },
    "headerImagePosition": {
      "type": "string"
    },
    "headerImageScale": {
      "type": "number"
    },
    "cardImagePosition": {
      "default": "center",
      "type": "string"
    },
    "cardImageScale": {
      "default": 1,
      "type": "number"
    },
    "description": {
      "type": "string",
      "minLength": 70
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "description"
  ]
}