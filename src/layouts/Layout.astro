---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  bodyClass?: string;
  description?: string;
  heroImage?: string;
  headerImagePosition?: string;
  headerImageScale?: number;
}
const { title, bodyClass, description, heroImage, headerImagePosition = 'center', headerImageScale = 1 } = Astro.props;
const siteTitle = 'Technical Scratches';
const siteDescription = 'Thoughts on software engineering and life as a developer';
const siteUrl = 'https://blog.danmarshall.dev';
const owner = 'Dan Marshall';
const currentYear = new Date().getFullYear();

const navArticles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const isArticlePage = bodyClass?.split(/\s+/).includes('article-detail') ?? false;

const backgroundImages = [
  heroImage ? { src: heroImage, position: headerImagePosition, scale: headerImageScale } : undefined,
  ...navArticles.map((article) => article.data.heroImage
    ? {
        src: article.data.heroImage,
        position: article.data.headerImagePosition ?? article.data.heroImagePosition,
        scale: article.data.headerImageScale ?? article.data.heroImageScale,
      }
    : undefined),
]
  .filter((image): image is { src: string; position: string; scale: number } => Boolean(image?.src))
  .slice(0, 12);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? siteDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" href={`${siteUrl}/feed.xml`} type="application/rss+xml" title={siteDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" />
    </noscript>
    <link rel="stylesheet" href="/styles/main.css" />
    <script is:inline>
      (function() {
        const getTheme = () => localStorage.getItem('theme') || 'light';
        const setTheme = (theme) => {
          localStorage.setItem('theme', theme);
          document.documentElement.setAttribute('data-theme', theme);
        };
        setTheme(getTheme());
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <aside class="contact-topbar" aria-label="Contact Dan Marshall">
      <a class="utility-icon" href="mailto:danmarshall909@gmail.com" aria-label="Email Dan Marshall" data-tooltip="Send me an email">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <path d="m3 7 9 6 9-6" />
        </svg>
      </a>
      <a class="utility-icon" href="https://www.linkedin.com/in/developerdan/" aria-label="Open Dan Marshall on LinkedIn" data-tooltip="View my LinkedIn profile">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V23h-4V8Zm7.5 0h3.83v2.05h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V23h-4v-7.85c0-1.87-.03-4.28-2.61-4.28-2.61 0-3.01 2.04-3.01 4.15V23h-4V8Z" />
        </svg>
      </a>
      <a class="utility-icon" href="https://github.com/DanMarshall909" aria-label="Open Dan Marshall on GitHub" data-tooltip="View my GitHub profile">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.15c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.17 1.18A10.99 10.99 0 0 1 12 6.06c.98 0 1.96.13 2.88.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.14c0 .31.21.67.8.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
        </svg>
      </a>
    </aside>

    <!-- Desktop top bar: back link only — hidden on mobile -->
    <div class="desktop-topbar">
      <a class="desktop-back" href="/" aria-label="Back to home" data-tooltip="Back to the homepage">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </a>
      {isArticlePage && (
        <button class="pdf-button" type="button" onclick="window.print()" aria-label="Create PDF from this article" data-tooltip="Print or save this page as PDF">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 6 2 18 2 18 9" />
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
            <rect x="6" y="14" width="12" height="8" />
          </svg>
        </button>
      )}
      <button class="theme-btn" onclick="toggleTheme()" aria-label="Toggle dark mode" data-tooltip="Switch light or dark theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>

    <!-- Mobile hamburger — hidden on desktop -->
    <button class="hamburger" id="hamburger" onclick="openDrawer()" aria-label="Open menu" data-tooltip="Open site menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Mobile drawer -->
    <div class="drawer-overlay" id="drawer-overlay" onclick="closeDrawer()"></div>
    <aside class="drawer" id="drawer">
      <div class="drawer-header">
        <a class="drawer-home" href="/" data-tooltip="Back to the homepage">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Home
        </a>
        <button class="theme-btn" onclick="toggleTheme()" aria-label="Toggle theme" data-tooltip="Switch light or dark theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="drawer-close" onclick="closeDrawer()" aria-label="Close" data-tooltip="Close the menu">✕</button>
      </div>
      <div class="drawer-body" id="drawer-body">
        <nav class="drawer-primary-nav" aria-label="Primary navigation">
          <a href="/" data-tooltip="Latest writing and featured posts">Writing</a>
          <a href="/topics/" data-tooltip="Browse articles by topic">Topics</a>
          <a href="/archive/" data-tooltip="Browse every article">Archive</a>
          <a href="/articles/resume/" data-tooltip="Read my current resume">Resume</a>
          <a href="mailto:danmarshall909@gmail.com" data-tooltip="Send me an email">Email Dan</a>
          <a href="https://www.linkedin.com/in/developerdan/" data-tooltip="View my LinkedIn profile">LinkedIn</a>
          <a href="https://github.com/DanMarshall909" data-tooltip="View my GitHub profile">GitHub</a>
          <a href="/feed.xml" data-tooltip="Subscribe to the RSS feed">RSS</a>
        </nav>
        {!isArticlePage && (
          <nav class="drawer-article-nav">
            <div class="drawer-nav-title">Articles</div>
            <ul>
              {navArticles.map(a => {
                const slug = a.id.replace(/\/index$/, '');
                return (
                  <li>
                    <a href={`/articles/${slug}/`}>{a.data.title}</a>
                    <span class="drawer-nav-date">{a.data.date.toLocaleDateString('en-AU', { year: 'numeric', month: 'short', timeZone: 'UTC' })}</span>
                  </li>
                );
              })}
            </ul>
          </nav>
        )}
      </div>
    </aside>

    <header class="header">
      <div
        class="site-background-slideshow"
        aria-hidden="true"
        data-background-images={JSON.stringify(backgroundImages)}
      >
        <div class="site-background-slide site-background-slide-a"></div>
        <div class="site-background-slide site-background-slide-b"></div>
      </div>
      <div class="content-wrap">
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/" data-tooltip="Latest writing and featured posts">Writing</a>
          <a href="/topics/" data-tooltip="Browse articles by topic">Topics</a>
          <a href="/archive/" data-tooltip="Browse every article">Archive</a>
          <a href="/articles/resume/" data-tooltip="Read my current resume">Resume</a>
          <a href="/feed.xml" data-tooltip="Subscribe to the RSS feed">RSS</a>
          <a href="mailto:danmarshall909@gmail.com" data-tooltip="Send me an email">Contact</a>
        </nav>
        <slot name="header">
          <div class="logo">
            <h1><a href="/">{siteTitle}</a></h1>
            <p class="description">{siteDescription}</p>
          </div>
        </slot>
      </div>
    </header>

    <div id="content">
      <div class="content-wrap">
        <slot />
      </div>
    </div>

    <footer>
      <div class="content-wrap">
        <slot name="footer-nav" />
        <section class="about">
          <p>Dan Marshall's blog</p>
        </section>
        <section class="copy">
          <p>&copy; {currentYear} {owner}</p>
        </section>
      </div>
    </footer>

    <script is:inline>
      // Drawer
      function openDrawer() {
        document.getElementById('drawer').classList.add('drawer-open');
        document.getElementById('drawer-overlay').classList.add('drawer-overlay-visible');
        document.getElementById('hamburger').setAttribute('aria-expanded', 'true');
      }

      function closeDrawer() {
        document.getElementById('drawer').classList.remove('drawer-open');
        document.getElementById('drawer-overlay').classList.remove('drawer-overlay-visible');
        document.getElementById('hamburger').setAttribute('aria-expanded', 'false');
      }

      // Table of contents — article pages only
      // Script is is:inline at bottom of body — DOM is already available, no need for DOMContentLoaded
      (function() {
        if (!document.body.classList.contains('article-detail')) return;

        var content = document.querySelector('section.content');
        if (!content) return;

        var longCodeBlocks = [];
        var longCodeThreshold = 14;

        function getCodeLineCount(pre) {
          var shikiLines = pre.querySelectorAll('.line');
          if (shikiLines.length) return shikiLines.length;

          var text = pre.textContent || '';
          var lines = text.split(/\r\n|\r|\n/);
          if (lines.length > 1 && lines[lines.length - 1] === '') lines.pop();
          return lines.length;
        }

        function setCodeToggleLabel(summary, details) {
          var lines = details.getAttribute('data-code-lines');
          summary.textContent = (details.open ? 'Hide code' : 'Show code') + ' (' + lines + ' lines)';
        }

        content.querySelectorAll('pre').forEach(function(pre) {
          if (pre.closest('.code-disclosure')) return;

          var lineCount = getCodeLineCount(pre);
          if (lineCount <= longCodeThreshold) return;

          var details = document.createElement('details');
          details.className = 'code-disclosure';
          details.setAttribute('data-code-lines', String(lineCount));

          var summary = document.createElement('summary');
          summary.className = 'code-disclosure-summary';
          details.appendChild(summary);

          pre.parentNode.insertBefore(details, pre);
          details.appendChild(pre);
          setCodeToggleLabel(summary, details);

          details.addEventListener('toggle', function() {
            setCodeToggleLabel(summary, details);
          });

          longCodeBlocks.push(details);
        });

        if (longCodeBlocks.length) {
          var printOpenedBlocks = [];
          window.addEventListener('beforeprint', function() {
            printOpenedBlocks = longCodeBlocks.filter(function(details) { return !details.open; });
            printOpenedBlocks.forEach(function(details) { details.open = true; });
          });
          window.addEventListener('afterprint', function() {
            printOpenedBlocks.forEach(function(details) { details.open = false; });
            printOpenedBlocks = [];
          });
        }

        var headings = content.querySelectorAll('h2, h3');
        if (headings.length < 2) return;

        function slugify(text) {
          return text.trim()
            .toLowerCase()
            .replace(/[^\w\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-{2,}/g, '-');
        }

        var usedIds = {};
        headings.forEach(function(h) {
          if (!h.id) {
            var base = slugify(h.textContent);
            var id = base;
            var n = 2;
            while (usedIds[id]) { id = base + '-' + n++; }
            h.id = id;
          }
          usedIds[h.id] = true;
        });

        var nav = document.createElement('nav');
        nav.className = 'toc';
        nav.setAttribute('aria-label', 'Table of contents');

        var titleEl = document.createElement('div');
        titleEl.className = 'toc-title';
        titleEl.innerHTML = '<span>On this page</span>';
        nav.appendChild(titleEl);

        var list = document.createElement('ul');
        list.className = 'toc-list';

        headings.forEach(function(h) {
          var li = document.createElement('li');
          li.className = 'toc-item toc-' + h.tagName.toLowerCase();
          var a = document.createElement('a');
          a.href = '#' + h.id;
          a.className = 'toc-link';
          a.textContent = h.textContent;
          a.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById(h.id).scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, null, '#' + h.id);
            closeDrawer();
          });
          li.appendChild(a);
          list.appendChild(li);
        });

        nav.appendChild(list);

        var hamburger = document.getElementById('hamburger');
        var isMobile = hamburger && window.getComputedStyle(hamburger).display !== 'none';

        if (isMobile) {
          // Mobile: put TOC inside the drawer
          var drawerBody = document.getElementById('drawer-body');
          if (drawerBody) drawerBody.appendChild(nav);
        } else {
          // Desktop: insert as sticky sidebar
          var article = document.querySelector('article.article');
          if (!article) return;
          article.parentElement.classList.add('article-with-toc');
          article.parentElement.insertBefore(nav, article);
        }

        // Highlight active heading via IntersectionObserver
        var tocLinks = [].slice.call(nav.querySelectorAll('.toc-link'));
        var activeLink = null;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var href = '#' + entry.target.id;
              if (activeLink) activeLink.classList.remove('toc-active');
              activeLink = tocLinks.find(function(l) { return l.getAttribute('href') === href; }) || null;
              if (activeLink) activeLink.classList.add('toc-active');
            }
          });
        }, { rootMargin: '-15% 0px -75% 0px', threshold: 0 });

        headings.forEach(function(h) { observer.observe(h); });
      })();
    </script>
    <script is:inline>
      function toggleTheme() {
        const current = document.documentElement.getAttribute('data-theme') || 'light';
        const next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        document.documentElement.setAttribute('data-theme', next);
      }
    </script>
    <script is:inline>
      (function () {
        const root = document.querySelector('.site-background-slideshow');
        if (!(root instanceof HTMLElement)) return;

        const rawImages = root.dataset.backgroundImages;
        if (!rawImages) return;

        let images = [];

        try {
          images = JSON.parse(rawImages);
        } catch {
          return;
        }

        images = images
          .map((image) => {
            if (typeof image === 'string') return { src: image, position: 'center' };
            if (!image || typeof image.src !== 'string') return null;
            return {
              src: image.src,
              position: typeof image.position === 'string' ? image.position : 'center',
              scale: typeof image.scale === 'number' ? image.scale : 1,
            };
          })
          .filter((image) => image && image.src.trim() !== '');

        if (images.length === 0) return;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const slides = [
          root.querySelector('.site-background-slide-a'),
          root.querySelector('.site-background-slide-b'),
        ].filter((slide) => slide instanceof HTMLElement);

        if (slides.length < 2) return;

        let imageIndex = 0;
        let activeSlideIndex = 0;

        function setSlideImage(slide, image) {
          slide.style.backgroundImage = `url("${image.src}")`;
          slide.style.backgroundPosition = image.position || 'center';
          slide.style.setProperty('--site-bg-scale-idle', String(1.04 * image.scale));
          slide.style.setProperty('--site-bg-scale-active', String(1.09 * image.scale));
        }

        function showNextImage() {
          const activeSlide = slides[activeSlideIndex];
          const inactiveSlide = slides[1 - activeSlideIndex];
          const nextImage = images[imageIndex % images.length];

          setSlideImage(inactiveSlide, nextImage);

          inactiveSlide.classList.add('is-active');
          activeSlide.classList.remove('is-active');

          activeSlideIndex = 1 - activeSlideIndex;
          imageIndex += 1;
        }

        setSlideImage(slides[0], images[0]);
        slides[0].classList.add('is-active');
        imageIndex = 1;

        if (prefersReducedMotion || images.length === 1) return;

        window.setInterval(showNextImage, 9000);
      })();
    </script>
  </body>
</html>
