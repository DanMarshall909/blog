---
import { Picture as AstroPicture } from 'astro:assets';
import { join } from 'node:path';
import sharp from 'sharp';

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}
const { src, alt, class: className, loading, fetchpriority } = Astro.props;
const pictureClass = className ? `${className}-picture` : undefined;
const assetPath = src.startsWith('/articles/') ? `../content${src}` : src;
const imageModules = import.meta.glob('../content/articles/**/*.{png,jpg,jpeg,webp,avif}', {
  eager: true,
  import: 'default',
});
const image = imageModules[assetPath] ?? src;
const imageDimensions = typeof image === 'string'
  ? await sharp(join(process.cwd(), 'public', image.replace(/^\//, ''))).metadata()
  : undefined;
---
<AstroPicture
  src={image}
  alt={alt}
  class={className}
  pictureAttributes={pictureClass ? { class: pictureClass } : undefined}
  formats={['avif', 'webp']}
  width={imageDimensions?.width}
  height={imageDimensions?.height}
  loading={loading}
  fetchpriority={fetchpriority}
/>
