---
import ArticleCard from './ArticleCard.astro';
import { getArticleCardImage, getIntroHtml, formatDate, getArticleSlug } from '../utils/article';
import { tagHref } from '../utils/tags';

interface ArticleEntry {
  id: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    heroImage?: string;
    cardImagePosition?: string;
    cardImageScale?: number;
    description?: string;
  };
  body?: string;
}

interface Props {
  articles: ArticleEntry[];
  storageKey: string;
  filterable?: boolean;
  filterVisibleCountSelector?: string;
}

const { articles, storageKey, filterable, filterVisibleCountSelector } = Astro.props;

const wrapperClass = [
  'article-list-view',
  filterable ? 'article-list-view--filterable' : '',
].filter(Boolean).join(' ');

const gridClass = 'article-grid' + (filterable ? ' collapsible-cards' : '');

function mapArticle(article: ArticleEntry, index: number) {
  const slug = getArticleSlug(article.id);
  const image = getArticleCardImage(article.id, article.data.heroImage, index);
  const intro = article.data.description
    ? `<p>${article.data.description}</p>`
    : getIntroHtml(article.data.description, article.body ?? '');
  const articleTags = filterable ? article.data.tags.map(t => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')) : [];
  const topicTagsStr = filterable ? articleTags.join(' ') : undefined;

  return { slug, image, intro, topicTagsStr };
}
---
<div class={wrapperClass}>
  <div class="view-toggle" role="radiogroup" aria-label="View mode">
    <button role="radio" aria-checked="true" data-view="grid" aria-label="Grid view">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
    </button>
    <button role="radio" aria-checked="false" data-view="list" aria-label="List view">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <div id="view-container" data-view="grid">
    <div class={gridClass}>
      {articles.map((article, index) => {
        const { slug, image, intro, topicTagsStr } = mapArticle(article, index);
        return (
          <ArticleCard
            title={article.data.title}
            href={`/articles/${slug}/`}
            dateTime={article.data.date.toISOString()}
            dateLabel={formatDate(article.data.date)}
            cardImage={image}
            cardImagePosition={article.data.cardImagePosition}
            cardImageScale={article.data.cardImageScale}
            primaryTag={article.data.tags[0]}
            tags={article.data.tags}
            summary={intro}
            topicTags={topicTagsStr}
            collapsible={filterable}
          />
        );
      })}
    </div>

    <div class="article-list">
      {articles.map((article) => {
        const slug = getArticleSlug(article.id);
        const articleTags = article.data.tags.map(t => t.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''));
        return (
          <div class="list-item" data-topic-tags={filterable ? articleTags.join(' ') : undefined}>
            <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
            <a href={`/articles/${slug}/`}>{article.data.title}</a>
              <span class="list-tags">
                {article.data.tags.slice(0, 3).map((tag) => (
                  <a href={tagHref(tag)}>{tag}</a>
                ))}
              </span>
          </div>
        );
      })}
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var wrapper = document.currentScript && document.currentScript.parentElement;
    if (!wrapper) return;
    var container = wrapper.querySelector('#view-container');
    if (!container) return;
    var buttons = wrapper.querySelectorAll('.view-toggle [role="radio"]');
    var storageKey = '{storageKey}';
    var filterVisibleCountSelector = '{filterVisibleCountSelector}';

    function setView(view) {
      container.setAttribute('data-view', view);
      buttons.forEach(function (b) {
        var active = b.getAttribute('data-view') === view;
        b.setAttribute('aria-checked', String(active));
      });
      try { localStorage.setItem(storageKey, view); } catch (_) {}
    }

    buttons.forEach(function (b) {
      b.addEventListener('click', function () {
        setView(b.getAttribute('data-view') || 'grid');
      });
    });

    try {
      var saved = localStorage.getItem(storageKey);
      if (saved === 'list' || saved === 'grid') setView(saved);
    } catch (_) {}

    if (wrapper.classList.contains('article-list-view--filterable')) {
      container.filterBy = function (filter) {
        var gridItems = container.querySelectorAll(':scope > .article-grid > .article-card');
        var listItems = container.querySelectorAll(':scope > .article-list > .list-item');
        var visible = 0;

        gridItems.forEach(function (card) {
          var tags = (card.getAttribute('data-topic-tags') || '').split(' ');
          var show = filter === 'all' || tags.indexOf(filter) !== -1;
          if (show) visible += 1;

          if (show) {
            card.hidden = false;
            card.removeAttribute('aria-hidden');
            requestAnimationFrame(function () {
              card.classList.remove('is-collapsed');
            });
          } else {
            card.classList.add('is-collapsed');
            card.setAttribute('aria-hidden', 'true');
            window.setTimeout(function () {
              if (card.classList.contains('is-collapsed')) card.hidden = true;
            }, 320);
          }
        });

        listItems.forEach(function (item) {
          var tags = (item.getAttribute('data-topic-tags') || '').split(' ');
          var show = filter === 'all' || tags.indexOf(filter) !== -1;
          item.classList.toggle('is-filtered-out', !show);
        });

        if (filterVisibleCountSelector) {
          var el = document.querySelector(filterVisibleCountSelector);
          if (el) el.textContent = String(visible);
        }
      };
    }
  })();
</script>

<style is:global>
  .article-list-view .view-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border: 1px solid rgb(83 45 18 / 0.32);
    border-radius: var(--border-radius);
    background-color: #d6b47e;
    background-image: var(--texture-light-wood);
    background-repeat: repeat;
    background-size: var(--texture-size-sm);
    box-shadow:
      inset 0 1px 0 rgb(255 247 220 / 0.4),
      inset 0 -1px 0 rgb(79 38 13 / 0.16),
      0 8px 18px rgb(42 24 12 / 0.2);
  }

  .article-list-view .view-toggle button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: calc(var(--border-radius) - 2px);
    background: transparent;
    color: #6b421f;
    cursor: pointer;
    font: inherit;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .article-list-view .view-toggle button[aria-checked="true"] {
    border-color: rgb(83 45 18 / 0.44);
    background: rgb(83 45 18 / 0.18);
    color: #2f170c;
    box-shadow:
      inset 0 1px 0 rgb(255 247 220 / 0.28),
      inset 0 -1px 0 rgb(79 38 13 / 0.18);
  }

  .article-list-view .view-toggle button:hover:not([aria-checked="true"]) {
    background: rgb(255 247 220 / 0.16);
    color: #2f170c;
  }

  .article-list-view .view-toggle svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: none;
    stroke: currentColor;
  }

  .article-list-view .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    perspective: 1200px;
    padding: var(--space-md);
    border: 1px solid rgb(83 45 18 / 0.28);
    border-radius: var(--border-radius);
    background-color: #d6b47e;
    background-image: var(--texture-light-wood);
    background-repeat: repeat;
    background-size: var(--texture-size-lg);
    box-shadow:
      inset 0 1px 0 rgb(255 247 220 / 0.42),
      inset 0 -1px 0 rgb(79 38 13 / 0.16),
      0 2px 0 rgb(255 237 190 / 0.18),
      0 16px 30px rgb(50 30 14 / 0.18),
      0 34px 64px rgb(50 30 14 / 0.12);
  }

  .article-list-view .article-list {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    border: 1px solid rgb(83 45 18 / 0.28);
    border-radius: var(--border-radius);
    background-color: #d6b47e;
    background-image: var(--texture-light-wood);
    background-repeat: repeat;
    background-size: var(--texture-size-lg);
    box-shadow:
      inset 0 1px 0 rgb(255 247 220 / 0.42),
      inset 0 -1px 0 rgb(79 38 13 / 0.16),
      0 2px 0 rgb(255 237 190 / 0.18),
      0 16px 30px rgb(50 30 14 / 0.18),
      0 34px 64px rgb(50 30 14 / 0.12);
  }

  .article-list-view [data-view="grid"] .article-list {
    display: none;
  }

  .article-list-view [data-view="list"] .article-grid {
    display: none;
  }

  .article-list-view .list-item {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    gap: var(--space-md);
    align-items: baseline;
    padding: var(--space-sm) var(--space-md);
    border-radius: calc(var(--border-radius) * 0.75);
    transition: background var(--transition-fast);
  }

  .article-list-view .list-item:hover {
    background: rgb(83 45 18 / 0.08);
  }

  .article-list-view .list-item time {
    color: #5a341d;
    font-size: var(--text-sm);
    font-weight: 700;
    white-space: nowrap;
    text-shadow: 0 1px 0 rgb(255 235 184 / 0.24);
  }

  .article-list-view .list-item a {
    color: #2f170c;
    font-family: var(--font-heading);
    font-weight: 700;
    text-decoration: none;
    text-shadow: 0 1px 0 rgb(255 235 184 / 0.28);
  }

  .article-list-view .list-item a:hover,
  .article-list-view .list-item a:focus-visible {
    color: var(--color-accent-hover);
  }

  .list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .list-tags a {
    padding: 0.1rem 0.35rem;
    border: 1px solid rgb(from var(--color-pill-border) r g b / 0.5);
    border-radius: var(--border-radius);
    background: rgb(from var(--color-pill-bg) r g b / 0.18);
    color: var(--color-pill-text);
    font-family: var(--font-primary);
    font-size: var(--text-xs);
    font-weight: 700;
    text-decoration: none;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .list-tags a:hover {
    border-color: rgb(from var(--color-pill-border) r g b / 0.9);
    background: rgb(from var(--color-pill-bg) r g b / 0.8);
  }

  /* ── Filterable mode (topics page) ──────────────────── */

  .article-list-view--filterable .article-grid {
    margin-top: var(--space-lg);
  }

  .article-list-view--filterable .article-grid > .article-card.collapsible {
    max-height: 18rem;
    overflow: hidden;
    transition:
      max-height var(--transition-smooth),
      opacity var(--transition-smooth),
      transform var(--transition-smooth),
      padding var(--transition-smooth),
      border-width var(--transition-smooth),
      margin var(--transition-smooth);
  }

  .article-list-view--filterable .article-grid > .article-card.collapsible.is-collapsed {
    max-height: 0;
    margin: calc(-1 * var(--space-xl)) 0 0;
    padding-top: 0;
    padding-bottom: 0;
    border-width: 0;
    opacity: 0;
    transform: translateY(-0.35rem);
    pointer-events: none;
  }

  .article-list-view--filterable .article-grid > .article-card.collapsible[hidden] {
    display: none;
  }

  .list-item.is-filtered-out {
    display: none;
  }

  @media (max-width: 600px) {
    .article-list-view .list-item {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
      padding: var(--space-sm) var(--space-xs);
    }

    .list-tags {
      display: none;
    }
  }
</style>
