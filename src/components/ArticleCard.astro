---
import { tagHref } from "../utils/tags";

interface Props {
  title: string;
  href: string;
  dateTime: string;
  dateLabel: string;
  cardImage: string;
  cardImagePosition?: string;
  cardImageScale?: number;
  variant?: "default" | "featured";
  primaryTag?: string;
  tags?: string[];
  summary?: string;
  topicTags?: string;
  noMiniTags?: boolean;
  collapsible?: boolean;
}

const {
  title,
  href,
  dateTime,
  dateLabel,
  cardImage,
  cardImagePosition = "center",
  cardImageScale = 1,
  variant = "default",
  primaryTag,
  tags = [],
  summary,
  topicTags,
  noMiniTags,
  collapsible,
} = Astro.props;

const isFeatured = variant === "featured";
const articleClass = isFeatured ? "article-card featured-card" : "article-card";
const articleClassList = collapsible
  ? `${articleClass} collapsible`
  : articleClass;
---

<article
  class={articleClassList}
  data-card-image={cardImage}
  data-card-image-position={cardImagePosition}
  data-card-image-scale={cardImageScale}
  data-topic-tags={topicTags}
>
  <a class="card-link" href={href} aria-label={`Read ${title}`}>
    <span>Read {title}</span>
  </a>

  {
    isFeatured ? (
      <div class="featured-card-copy">
        <h3>
          <>
            <a href={href}>{title}</a>
            <div class="article-card-meta">
              <time datetime={dateTime}>{dateLabel}</time>
            </div>
          </>
        </h3>
        {summary && <div class="featured-summary" set:html={summary} />}
      </div>
    ) : (
      <>
        <h3>
          <>
            <a href={href}>{title}</a>
            <div class="article-card-meta">
              <time datetime={dateTime}>{dateLabel}</time>
            </div>
          </>
        </h3>
        {summary && <div class="article-card-summary" set:html={summary} />}
        {!noMiniTags && tags.length > 0 && (
          <ul class="mini-tag-list" aria-label="Article topics">
            {tags.slice(0, 3).map((tag) => (
              <li>
                <a href={tagHref(tag)}>{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </>
    )
  }
</article>

<script>
  document.querySelectorAll("[data-card-image]").forEach((card) => {
    if (!(card instanceof HTMLElement)) return;
    card.style.setProperty(
      "--card-bg-image",
      `url("${card.dataset.cardImage}")`,
    );
    card.style.setProperty(
      "--card-bg-position",
      card.dataset.cardImagePosition || "center",
    );
    card.style.setProperty(
      "--card-bg-scale",
      card.dataset.cardImageScale || "1",
    );
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    if (event.target.closest("a, button")) return;

    const card = event.target.closest(".article-card, .featured-card");
    const link = card?.querySelector(".card-link");

    if (link instanceof HTMLAnchorElement) {
      link.click();
    }
  });
</script>
