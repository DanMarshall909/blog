---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { tagSlug } from '../../utils/tags';

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-AU', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

function getTagArticleCardImage(articleId: string, heroImage: string | undefined): string {
  return heroImage ?? '/articles/ai-blog-pipeline/cartoon.png';
}

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const tags = new Map<string, string>();

  for (const article of articles) {
    for (const tag of article.data.tags) {
      const slug = tagSlug(tag);
      if (!tags.has(slug)) tags.set(slug, tag);
    }
  }

  return [...tags.entries()].map(([slug, tag]) => ({
    params: { tag: slug },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const slug = tagSlug(tag);
const articles = (await getCollection('articles'))
  .filter((article) => article.data.tags.some((articleTag) => tagSlug(articleTag) === slug))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Layout title={`${tag} articles - Technical Scratches`} description={`Articles tagged ${tag} on Technical Scratches.`}>
  <section class="tag-page">
    <p class="eyebrow">Tagged</p>
    <h1>{tag}</h1>
    <p>{articles.length} {articles.length === 1 ? 'article' : 'articles'} filed here.</p>

    <ul class="tag-article-list">
      {articles.map((article) => {
        const articleSlug = article.id.replace(/\/index$/, '');
        const cardImage = getTagArticleCardImage(article.id, article.data.heroImage);
        return (
          <li class="article-card tag-article-card" data-card-image={cardImage}>
            <a class="card-link" href={`/articles/${articleSlug}/`} aria-label={`Read ${article.data.title}`}><span>Read {article.data.title}</span></a>
            <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
            <a href={`/articles/${articleSlug}/`}>{article.data.title}</a>
            <p>{article.data.description}</p>
          </li>
        );
      })}
    </ul>
  </section>

  <script is:inline>
    document.querySelectorAll('[data-card-image]').forEach((card) => {
      card.style.setProperty('--card-bg-image', `url("${card.dataset.cardImage}")`);
    });

    document.addEventListener('click', (event) => {
      if (event.target.closest('a, button')) return;

      const card = event.target.closest('.featured-card, .article-card');
      const link = card?.querySelector('.card-link');
      if (link instanceof HTMLAnchorElement) {
        link.click();
      }
    });
  </script>
</Layout>
