---
import Layout from '../../layouts/Layout.astro';
import Picture from '../../components/Picture.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { tagHref } from '../../utils/tags';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => {
    // Strip trailing /index from id to get the URL slug
    // e.g. "1bit-llm/index" → "1bit-llm"
    const slug = article.id.replace(/\/index$/, '');
    return {
      params: { slug },
      props: { article },
    };
  });
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await render(article);
const readingMinutes = Math.max(1, Math.round((article.body ?? '').split(/\s+/).filter(Boolean).length / 220));

const formattedDate = article.data.date.toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: '2-digit',
  timeZone: 'UTC',
});

// Derive URL slug from id
const urlSlug = article.id.replace(/\/index$/, '');
const pageClass = `article-detail article-${urlSlug.replace(/[^a-z0-9-]/gi, '-').toLowerCase()}`;
---
<Layout
  title={`${article.data.title} - Technical Scratches`}
  bodyClass={pageClass}
  description={article.data.description}
  heroImage={article.data.heroImage}
  headerImagePosition={article.data.headerImagePosition ?? article.data.heroImagePosition}
  headerImageScale={article.data.headerImageScale ?? article.data.heroImageScale}
>
  <Fragment slot="header">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Writing</a>
      <span aria-hidden="true">/</span>
      <span>{article.data.title}</span>
    </nav>
    <div class="title-with-image">
      <h1>{article.data.title}</h1>
    </div>
    <div class="article-meta">
      {article.data.date && <p class="publish-date">{formattedDate}</p>}
      <p class="reading-time">{readingMinutes} min read</p>
      {article.data.tags.length > 0 && (
        <ul class="tags" aria-label="Article topics">
          {article.data.tags.map(tag => (
            <li><a class="tag" href={tagHref(tag)}>{tag}</a></li>
          ))}
        </ul>
      )}
    </div>
  </Fragment>

  <article
    id="article-start"
    class={`article${article.data.heroImage ? ' has-hero' : ''}`}
    style={`--hero-image-position: ${article.data.heroImagePosition}; --hero-image-scale: ${article.data.heroImageScale};`}
  >
    <section class="content">
      {article.data.heroImage && (
        <Picture
          class="hero-image"
          src={article.data.heroImage}
          alt={article.data.title}
          loading="eager"
          fetchpriority="high"
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      )}
      <Content />
    </section>
  </article>

  <Fragment slot="footer-nav">
    <div class="nav">
      <a href="/">&laquo; Full blog</a>
    </div>
  </Fragment>

  <script is:inline>
    (function () {
      if (window.location.hash) return;
      if (!window.matchMedia('(max-width: 768px)').matches) return;

      var navigationEntry = performance.getEntriesByType('navigation')[0];
      if (navigationEntry && navigationEntry.type === 'back_forward') return;

      function scrollToArticleStart() {
        var articleStart = document.getElementById('article-start');
        if (!articleStart) return;
        articleStart.scrollIntoView({ block: 'start', inline: 'nearest' });
      }

      requestAnimationFrame(function () {
        requestAnimationFrame(scrollToArticleStart);
      });

      window.addEventListener('load', scrollToArticleStart, { once: true });
    })();
  </script>
</Layout>
