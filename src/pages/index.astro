---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { tagHref } from '../utils/tags';

const heroImageOverrides = new Map<string, string>();

const articleFallbackImages = [
  '/articles/ai-blog-pipeline/cartoon.png',
  '/articles/1bit-llm/cartoon.png',
  '/articles/claude-code-mcp-token-waste/cartoon.png',
  '/articles/bankers-rounding/cartoon.png',
];

const topicGroups = [
  'AI',
  'developer tools',
  'Astro',
  'C#',
  'Python',
  'Rust',
  'CSS',
  'productivity',
  'career',
  'testing',
];

const excludedArticleIds = new Set([
  'resume',
  'resume/index',
  'resume-brief',
  'resume-brief/index',
]);

const allArticles = await getCollection('articles');

const resumeArticle = allArticles.find(a => a.id === 'resume' || a.id === 'resume/index');

const articles = allArticles
  .filter((article) => !excludedArticleIds.has(article.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featuredArticle, ...recentArticles] = articles;

function getArticleSlug(articleId: string): string {
  return articleId.replace(/\/index$/, '');
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-AU', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
}

function getArticleCardImage(
  articleId: string,
  heroImage: string | undefined,
  fallbackIndex = 0,
): string {
  return (
    heroImageOverrides.get(articleId) ??
    heroImage ??
    articleFallbackImages[fallbackIndex % articleFallbackImages.length]
  );
}

function escapeHtml(value: string): string {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function markdownInlineToHtml(value: string): string {
  return escapeHtml(value)
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>')
    .replace(/_([^_]+)_/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
}

// Extract the first prose paragraph from raw markdown body.
// Skips headings, image lines, and thematic breaks.
function getIntroHtml(description: string | undefined, body: string): string {
  if (description?.trim()) {
    return `<p>${escapeHtml(description.trim())}</p>`;
  }

  const paragraphLines: string[] = [];

  for (const line of body.split('\n')) {
    const trimmed = line.trim();

    if (/^#{1,6}\s/.test(trimmed)) continue;
    if (trimmed === '---') continue;
    if (/^!\[/.test(trimmed)) continue;

    if (trimmed === '' && paragraphLines.length > 0) break;
    if (trimmed !== '') paragraphLines.push(trimmed);
  }

  if (paragraphLines.length === 0) {
    return '';
  }

  return `<p>${markdownInlineToHtml(paragraphLines.join(' '))}</p>`;
}
---

<Layout title="Technical Scratches" bodyClass="home-page">
  <Fragment slot="footer-nav">
    <div class="nav">
      <a href="/archive/">&laquo; Archives</a>
    </div>
  </Fragment>

  <div class="page-with-toc">
    <nav class="toc home-toc" aria-label="Table of contents">
      <div class="toc-utility-links">
        <a href="/" aria-label="Back to home" data-tooltip="Back to the homepage">
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        </a>
        <a href="mailto:danmarshall909@gmail.com" aria-label="Email Dan Marshall" data-tooltip="Send me an email">
          <svg aria-hidden="true" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="m3 7 9 6 9-6"></path></svg>
        </a>
        <a href="https://www.linkedin.com/in/developerdan/" aria-label="Open Dan Marshall on LinkedIn" data-tooltip="View my LinkedIn profile">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V23h-4V8Zm7.5 0h3.83v2.05h.05c.53-1 1.84-2.05 3.79-2.05 4.05 0 4.8 2.67 4.8 6.14V23h-4v-7.85c0-1.87-.03-4.28-2.61-4.28-2.61 0-3.01 2.04-3.01 4.15V23h-4V8Z"></path></svg>
        </a>
        <a href="https://github.com/DanMarshall909" aria-label="Open Dan Marshall on GitHub" data-tooltip="View my GitHub profile">
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.15c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.17 1.18A10.99 10.99 0 0 1 12 6.06c.98 0 1.96.13 2.88.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.11 3.04.74.8 1.19 1.83 1.19 3.08 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.14c0 .31.21.67.8.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"></path></svg>
        </a>
      </div>
      <div class="toc-title"><span>On this page</span></div>
      <ul class="toc-list">
        <li class="toc-item"><a class="toc-link toc-active" href="#featured-title">Featured article</a></li>
        <li class="toc-item"><a class="toc-link" href="#recent-title">Notes from the workbench</a></li>
      </ul>
    </nav>

    <div class="home-main-content">
      {
        featuredArticle && (() => {
          const slug = getArticleSlug(featuredArticle.id);
          const intro = getIntroHtml(featuredArticle.data.description, featuredArticle.body ?? '');
          const primaryTag = featuredArticle.data.tags[0];
          const image = getArticleCardImage(
            featuredArticle.id,
            featuredArticle.data.heroImage,
          );

          return (
            <section class="featured-writing" aria-labelledby="featured-title">
              <h2 id="featured-title" class="sr-only">Featured writing</h2>
              <div class="featured-card-row">
                <div class="featured-card-column">
                  <p class="eyebrow">Featured article</p>

                  <ArticleCard
                    variant="featured"
                    title={featuredArticle.data.title}
                    href={`/articles/${slug}/`}
                    dateTime={featuredArticle.data.date.toISOString()}
                    dateLabel={formatDate(featuredArticle.data.date)}
                    cardImage={image}
                    cardImagePosition={featuredArticle.data.cardImagePosition}
                    cardImageScale={featuredArticle.data.cardImageScale}
                    primaryTag={primaryTag}
                    summary={intro}
                  />
                </div>

                <div class="featured-card-column">
                  {resumeArticle && (() => {
                    const resumeSlug = getArticleSlug(resumeArticle.id);
                    const resumeIntro = getIntroHtml(resumeArticle.data.description, resumeArticle.body ?? '');
                    const resumeImage = resumeArticle.data.heroImage ?? '/articles/resume/profile-alpha-trimmed.png';
                    return (
                      <ArticleCard
                        variant="featured"
                        title={resumeArticle.data.title}
                        href={`/articles/${resumeSlug}/`}
                        dateTime={resumeArticle.data.date.toISOString()}
                        dateLabel={formatDate(resumeArticle.data.date)}
                        cardImage={resumeImage}
                        cardImagePosition={resumeArticle.data.cardImagePosition}
                        cardImageScale={resumeArticle.data.cardImageScale}
                        primaryTag={resumeArticle.data.tags[0]}
                        tags={resumeArticle.data.tags}
                        summary={resumeIntro}
                      />
                    );
                  })()}
                </div>
              </div>
            </section>
          );
        })()
      }

      <section class="recent-writing" aria-labelledby="recent-title">
        <div class="page-header-row">
          <div class="section-heading">
            <p class="eyebrow">Recent writing</p>
            <h2 id="recent-title">Notes from the workbench</h2>
          </div>

          <div class="view-toggle" role="radiogroup" aria-label="View mode">
            <button role="radio" aria-checked="true" data-view="grid" aria-label="Grid view">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            </button>
            <button role="radio" aria-checked="false" data-view="list" aria-label="List view">
              <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>

        <div id="view-container" data-view="grid">
          <div class="article-grid">
            {
              recentArticles.map((article, index) => {
                const slug = getArticleSlug(article.id);
                const intro = getIntroHtml(article.data.description, article.body ?? '');
                const primaryTag = article.data.tags[0];
                const image = getArticleCardImage(article.id, article.data.heroImage, index);

                return (
                  <ArticleCard
                    title={article.data.title}
                    href={`/articles/${slug}/`}
                    dateTime={article.data.date.toISOString()}
                    dateLabel={formatDate(article.data.date)}
                    cardImage={image}
                    cardImagePosition={article.data.cardImagePosition}
                    cardImageScale={article.data.cardImageScale}
                    primaryTag={primaryTag}
                    tags={article.data.tags}
                    summary={intro}
                  />
                );
              })
            }
          </div>

          <div class="article-list">
            {
              recentArticles.map((article) => {
                const slug = getArticleSlug(article.id);
                return (
                  <div class="list-item">
                    <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
                    <a href={`/articles/${slug}/`}>{article.data.title}</a>
                  </div>
                );
              })
            }
          </div>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    (function () {
      var container = document.getElementById('view-container');
      if (!container) return;
      var buttons = container.parentElement.querySelectorAll('.view-toggle [role="radio"]');
      var storageKey = 'view-mode-home';

      function setView(view) {
        container.setAttribute('data-view', view);
        buttons.forEach(function (b) {
          var active = b.getAttribute('data-view') === view;
          b.setAttribute('aria-checked', String(active));
        });
        try { localStorage.setItem(storageKey, view); } catch (_) {}
      }

      buttons.forEach(function (b) {
        b.addEventListener('click', function () {
          setView(b.getAttribute('data-view') || 'grid');
        });
      });

      try {
        var saved = localStorage.getItem(storageKey);
        if (saved === 'list' || saved === 'grid') setView(saved);
      } catch (_) {}
    })();
  </script>

  <section class="topic-cloud" aria-labelledby="topics-title">
    <div class="section-heading">
      <p class="eyebrow">Topics</p>
      <h2 id="topics-title">What I keep coming back to</h2>
    </div>

    <ul>
      {topicGroups.map((topic) => (
        <li>
          <a href={tagHref(topic)}>{topic}</a>
        </li>
      ))}
      <li>
        <a href="/topics/">All topics</a>
      </li>
    </ul>
  </section>

</Layout>
