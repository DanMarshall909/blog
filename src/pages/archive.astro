---
import Layout from '../layouts/Layout.astro';
import ArticleListView from '../components/ArticleListView.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Layout
  title="Archive - Technical Scratches"
  headerVariant="section"
>
  <section class="archive">
    <div class="page-header-row">
      <div class="section-heading">
        <p class="eyebrow">Archive</p>
        <h1>All writing in one place</h1>
        <p class="section-description">A full index of posts, sketches, and experiments from the workbench.</p>
      </div>
    </div>

    <ArticleListView
      articles={articles}
      storageKey="view-mode-archive"
    />
  </section>
</Layout>
